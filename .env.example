# Local Supabase values.
# After Docker is running, start Supabase with:
#   pnpm supabase:start
# Then copy real values from:
#   pnpm supabase:status

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key-from-supabase-status

# Server-only. Never expose this to browser/client code.
SUPABASE_SECRET_KEY=replace-with-local-secret-key-from-supabase-status
