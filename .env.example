# Local Supabase values.
# After Docker is running, start Supabase with:
#   pnpm supabase:start
# Then copy real values from:
#   pnpm supabase:status

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key-from-supabase-status

# Server-only. Never expose this to browser/client code.
SUPABASE_SECRET_KEY=replace-with-local-secret-key-from-supabase-status

# For SMS through 46elks. Server-only; never expose these to browser code.
ELK46_USER=replace-with-46elks-api-username
ELK46_PASSWORD=replace-with-46elks-api-password
# Optional sender. Use 1-11 alphanumeric characters or an E.164 phone number.
ELK46_FROM=Wedding
# Optional local/e2e mock mode. Set to 1 to avoid real provider sends.
ELK46_MOCK_SEND=0
# Used by `pnpm sms:test`.
ELK46_TEST_PHONE_NUMBER=+46700000000
